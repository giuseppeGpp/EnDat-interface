  72              	#define CRT0_INIT_DTCM                      TRUE
  73              	#endif
  74              	
  75              	/**
  76              	 * @brief   Enforces initialization of MSP.
  77              	 * @note    This is required if the boot process is not reliable for whatever
  78              	 *          reason (bad ROMs, bad bootloaders, bad debuggers).
  79              	 */
