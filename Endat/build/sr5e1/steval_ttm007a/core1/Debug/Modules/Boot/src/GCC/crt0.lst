  53              	
  54              	/**
  55              	 * @brief   RAM initialization switch.
  56              	 */
  57              	#if !defined(CRT0_INIT_RAM) || defined(__DOXYGEN__)
  58              	#define CRT0_INIT_RAM                       TRUE
  59              	#endif
  60              	
  61              	/**
  62              	 * @brief   ITCM initialization switch.
  63              	 */
