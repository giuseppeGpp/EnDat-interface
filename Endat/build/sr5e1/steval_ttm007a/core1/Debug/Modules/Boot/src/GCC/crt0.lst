 216              	                /* Copying any data linked into ITCM within core ITCM */
 217 0020 3E4A     	                ldr     r2, =__itcm_size__
 218              	                /* If __itcm_size__ == 0 => nothing to copy */
 219 0022 002A     	                cmp     r2, #0
 220 0024 08D0     	                beq     itcmdone
 221              	
